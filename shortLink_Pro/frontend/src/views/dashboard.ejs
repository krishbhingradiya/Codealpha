<%- include('partials/header') %>

<main class="dashboard-section">
  <div class="dash-container">
    
    <!-- Smart Workspace Title -->
    <div class="dash-header" style="margin-bottom: 2rem;">
      <div>
        <h1 class="dash-title">Smart Workspace</h1>
        <p class="dash-subtitle">Your central hub to shorten, access, and track your most important vanity links.</p>
      </div>
    </div>

    <!-- Workspace Top Insight Snippets (Practical, Decision-Oriented Metrics) -->
    <section class="workspace-insights">
      
      <!-- Top Performing Link -->
      <div class="glass-panel insight-snippet">
        <div class="insight-meta">
          <span class="insight-label">Your Top Performing Link</span>
          <span class="insight-val" id="topPerformingLinkVal">Loading...</span>
        </div>
        <span class="insight-icon">🔥</span>
      </div>

      <!-- Trending Link -->
      <div class="glass-panel insight-snippet">
        <div class="insight-meta">
          <span class="insight-label">Trending Link</span>
          <span class="insight-val" id="trendingLinkVal">Loading...</span>
        </div>
        <span class="insight-icon">📈</span>
      </div>

      <!-- Active Catalog Rate -->
      <div class="glass-panel insight-snippet">
        <div class="insight-meta">
          <span class="insight-label">Active Catalog Health</span>
          <span class="insight-val" id="activeCatalogVal">Loading...</span>
        </div>
        <span class="insight-icon">🛡️</span>
      </div>

    </section>

    <!-- Raycast-like Instant Shorten Command Bar -->
    <div class="glass-panel workspace-command-bar" style="margin-bottom: 2.5rem; padding: 1.5rem;">
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <span style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--clr-muted); letter-spacing: 0.5px;">⚡ Quick Link Command</span>
        <form id="workspaceShortenForm" style="display: flex; gap: 1rem; flex-wrap: wrap;">
          <input type="url" id="workspaceUrlInput" class="form-control" placeholder="Paste long URL to shorten instantly..." required style="flex: 1; min-width: 250px;">
          <input type="text" id="workspaceCustomInput" class="form-control" placeholder="Custom Alias (Optional)" style="max-width: 200px; min-width: 120px;">
          <button type="submit" class="btn btn-primary" id="workspaceShortenBtn">
            Shorten
          </button>
        </form>
      </div>
    </div>

    <!-- Dynamic Pinned Links Workspace -->
    <div class="glass-panel workspace-card-large" id="pinnedLinksPanel" style="margin-bottom: 2.5rem; padding: 2rem;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; border-bottom: 1px solid rgba(255, 255, 255, 0.04); padding-bottom: 0.75rem;">
        <h3 style="font-size: 1.15rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;">
          📌 Pinned Links
        </h3>
        <span class="text-muted" style="font-size: 0.8rem;">Instantly accessible redirects</span>
      </div>
      <div class="workspace-link-list" id="pinnedLinksList">
        <p class="text-muted" style="text-align: center; padding: 2rem 0;">Pin links in your manager workspace to keep them here.</p>
      </div>
    </div>

    <!-- Onboarding Panel (shown when no links are created) -->
    <div class="glass-panel" id="workspaceOnboarding" style="display: none; padding: 2.5rem; text-align: center; max-width: 800px; margin: 0 auto 2.5rem;">
      <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">✨</div>
      <h2 style="font-size: 1.35rem; font-weight: 600; margin-bottom: 0.5rem; font-family: 'Outfit', sans-serif;">Welcome to your Smart Workspace</h2>
      <p class="text-muted" style="max-width: 500px; margin: 0 auto 2rem; font-size: 0.9rem; line-height: 1.5;">
        This is your central command center. Let's make it yours! Shorten your first link above to see click trends and activity event logging.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; text-align: left;">
        <div style="background: rgba(255, 255, 255, 0.01); padding: 1.25rem; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.04);">
          <span style="font-size: 1.25rem; margin-bottom: 0.5rem; display: block;">⚡</span>
          <h4 style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.25rem; color: #fff;">1. Quick Shorten</h4>
          <p class="text-muted" style="font-size: 0.8rem; line-height: 1.4; margin: 0;">Use the inline command bar above to instantly shorten any URL.</p>
        </div>
        <div style="background: rgba(255, 255, 255, 0.01); padding: 1.25rem; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.04);">
          <span style="font-size: 1.25rem; margin-bottom: 0.5rem; display: block;">📌</span>
          <h4 style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.25rem; color: #fff;">2. Pin Key Links</h4>
          <p class="text-muted" style="font-size: 0.8rem; line-height: 1.4; margin: 0;">Navigate to the <a href="/console" class="text-accent" style="text-decoration: none; font-weight: 500;">Link Manager</a> and pin key links to keep them on your workspace.</p>
        </div>
        <div style="background: rgba(255, 255, 255, 0.01); padding: 1.25rem; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.04);">
          <span style="font-size: 1.25rem; margin-bottom: 0.5rem; display: block;">⭐</span>
          <h4 style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.25rem; color: #fff;">3. Mark Favorites</h4>
          <p class="text-muted" style="font-size: 0.8rem; line-height: 1.4; margin: 0;">Star your most crucial links to group them under favorites.</p>
        </div>
      </div>
    </div>

    <!-- Workspace Grid Layout for Favorites, Recents, and Top Performance -->
    <div class="workspace-grid-split" id="workspaceGridSplit">
      
      <!-- Left: Favorite Links -->
      <div class="glass-panel" style="padding: 2rem;">
        <div style="margin-bottom: 1.5rem; border-bottom: 1px solid rgba(255, 255, 255, 0.04); padding-bottom: 0.75rem;">
          <h3 style="font-size: 1.15rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;">
            ⭐ Favorite Links
          </h3>
        </div>
        <div class="workspace-link-list" id="favoriteLinksList">
          <p class="text-muted" style="text-align: center; padding: 2rem 0;">Star your favorite links to access them quickly.</p>
        </div>
      </div>

      <!-- Right: Most Visited Links -->
      <div class="glass-panel" style="padding: 2rem;">
        <div style="margin-bottom: 1.5rem; border-bottom: 1px solid rgba(255, 255, 255, 0.04); padding-bottom: 0.75rem;">
          <h3 style="font-size: 1.15rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;">
            🚀 Top Visited Links
          </h3>
        </div>
        <div class="workspace-link-list" id="topVisitedLinksList">
          <p class="text-muted" style="text-align: center; padding: 2rem 0;">Trending links with highest clicks will show here.</p>
        </div>
      </div>

    </div>

    <!-- Bottom: Recent Activities Feed -->
    <div class="glass-panel" id="recentActivityPanel" style="margin-top: 2.5rem; padding: 2rem;">
      <div style="margin-bottom: 1.5rem; border-bottom: 1px solid rgba(255, 255, 255, 0.04); padding-bottom: 0.75rem;">
        <h3 style="font-size: 1.15rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;">
          🕒 Recent Link Events
        </h3>
      </div>
      <div class="workspace-activity-feed" id="recentActivityList">
        <p class="text-muted" style="text-align: center; padding: 1rem 0;">Loading activity data...</p>
      </div>
    </div>

  </div>
</main>

<!-- QR Code view overlay popup used across lists -->
<div class="modal-overlay" id="qrModal">
  <div class="modal-card glass-panel text-center" style="max-width: 400px; padding: 2rem;">
    <div class="modal-header">
      <h3 style="font-size: 1.1rem; font-weight: 600;">📱 QR Code</h3>
      <button class="modal-close" onclick="document.getElementById('qrModal').classList.remove('active')">&times;</button>
    </div>
    <div class="qr-modal-body" style="margin-top: 1rem;">
      <img id="qrModalImage" src="" alt="Branded QR Code" style="width: 180px; height: 180px; background: white; padding: 8px; border-radius: 8px; margin: 0 auto 1.25rem;">
      <div id="qrModalUrl" style="font-size: 0.9rem; color: var(--clr-accent); word-break: break-all; margin-bottom: 1.5rem; font-family: monospace;"></div>
      <button id="qrDownloadBtn" class="btn btn-primary btn-sm" style="width: 100%;">Download QR Image</button>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
