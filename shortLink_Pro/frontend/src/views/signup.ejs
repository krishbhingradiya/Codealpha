<%- include('partials/header') %>

<main class="auth-layout">
  <div class="auth-container">
    
    <!-- Left Column: Signup Onboarding Panel -->
    <div class="auth-form-panel glass-panel" style="animation: scaleUp 0.3s ease-out forwards; min-height: 480px; display: flex; flex-direction: column; justify-content: center;">
      
      <!-- STEP 1: Enter Name & Email -->
      <div id="signupStep1" class="auth-step-panel active">
        <h2 style="font-size: 1.85rem; margin-bottom: 0.5rem; font-family: var(--font-heading); text-align: left;">Get Started</h2>
        <p class="text-muted" style="margin-bottom: 2rem; font-size: 0.9rem; text-align: left;">Create your free ShortLink Pro account</p>

        <form id="signupForm1" style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div class="form-group" style="text-align: left;">
            <label for="signupName" style="display: block; font-size: 0.85rem; color: var(--clr-muted); margin-bottom: 0.5rem; font-weight: 500;">Full Name</label>
            <input type="text" id="signupName" class="form-control" placeholder="Krish Patel" required>
          </div>
          <div class="form-group" style="text-align: left;">
            <label for="signupEmail" style="display: block; font-size: 0.85rem; color: var(--clr-muted); margin-bottom: 0.5rem; font-weight: 500;">Email Address</label>
            <input type="email" id="signupEmail" class="form-control" placeholder="you@example.com" required>
          </div>

          <button type="submit" class="btn btn-primary" id="btnSignup1" style="width: 100%; font-family: var(--font-heading); font-weight: 600; padding: 0.85rem; margin-top: 0.5rem;">
            <span class="btn-text">Send Verification Code</span>
            <div class="btn-loader" style="display: none;">
              <span class="spinner-sm"></span>
              <span>Sending OTP...</span>
            </div>
          </button>
        </form>

        <!-- Social Signups placeholder -->
        <div style="margin-top: 1.75rem; display: flex; flex-direction: column; gap: 0.75rem;">
          <div style="display: flex; align-items: center; text-align: center;">
            <hr style="flex: 1; border-color: rgba(255,255,255,0.06); border-style: solid; border-width: 1px 0 0 0;">
            <span style="padding: 0 10px; font-size: 0.75rem; color: var(--clr-muted); text-transform: uppercase; letter-spacing: 0.5px;">Or continue with</span>
            <hr style="flex: 1; border-color: rgba(255,255,255,0.06); border-style: solid; border-width: 1px 0 0 0;">
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
            <button type="button" class="btn btn-secondary btn-sm" id="googleSignupBtn" style="font-weight: 500;">Google</button>
            <button type="button" class="btn btn-secondary btn-sm" id="githubSignupBtn" style="font-weight: 500;">GitHub</button>
          </div>
        </div>

        <p class="text-muted" style="text-align: center; margin-top: 2rem; font-size: 0.85rem; margin-bottom: 0;">
          Already have an account? <a href="/login" style="color: var(--clr-accent); font-weight: 600;">Sign in</a>
        </p>
      </div>

      <!-- STEP 2: Verify OTP -->
      <div id="signupStep2" class="auth-step-panel">
        <h2 style="font-size: 1.85rem; margin-bottom: 0.5rem; font-family: var(--font-heading); text-align: left;">Verify Your Email</h2>
        <p class="text-muted" id="otpSentMessage" style="margin-bottom: 1.5rem; font-size: 0.9rem; text-align: left;">Verification code sent to your email.</p>

        <form id="signupForm2" style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div class="otp-container" id="signupOtpContainer">
            <input type="text" maxlength="1" class="otp-input" pattern="[0-9]" inputmode="numeric" required>
            <input type="text" maxlength="1" class="otp-input" pattern="[0-9]" inputmode="numeric" required>
            <input type="text" maxlength="1" class="otp-input" pattern="[0-9]" inputmode="numeric" required>
            <input type="text" maxlength="1" class="otp-input" pattern="[0-9]" inputmode="numeric" required>
            <input type="text" maxlength="1" class="otp-input" pattern="[0-9]" inputmode="numeric" required>
            <input type="text" maxlength="1" class="otp-input" pattern="[0-9]" inputmode="numeric" required>
          </div>

          <button type="submit" class="btn btn-primary" id="btnSignup2" style="width: 100%; font-family: var(--font-heading); font-weight: 600; padding: 0.85rem;">
            <span class="btn-text">Verify OTP</span>
            <div class="btn-loader" style="display: none;">
              <span class="spinner-sm"></span>
              <span>Verifying code...</span>
            </div>
          </button>
        </form>

        <div class="otp-timer-container">
          Didn't receive a code? 
          <button type="button" class="resend-otp-btn" id="resendOtpBtn" disabled>Resend Code</button>
          <span id="resendTimerText">(60s)</span>
        </div>

        <p class="text-muted" style="text-align: center; margin-top: 1.5rem; font-size: 0.85rem; margin-bottom: 0;">
          Entered wrong email? <a href="#" id="changeEmailLink" style="color: var(--clr-accent); font-weight: 600;">Go Back</a>
        </p>
      </div>

      <!-- STEP 3: Set Password -->
      <div id="signupStep3" class="auth-step-panel">
        <h2 style="font-size: 1.85rem; margin-bottom: 0.5rem; font-family: var(--font-heading); text-align: left;">Secure Your Account</h2>
        <p class="text-muted" style="margin-bottom: 1.5rem; font-size: 0.9rem; text-align: left;">Choose a strong password to complete onboarding.</p>

        <form id="signupForm3" style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div class="form-group" style="text-align: left;">
            <label for="signupPassword" style="display: block; font-size: 0.85rem; color: var(--clr-muted); margin-bottom: 0.5rem; font-weight: 500;">Password</label>
            <div style="position: relative;">
              <input type="password" id="signupPassword" class="form-control" placeholder="••••••••" required style="padding-right: 3.5rem;" minlength="6">
              <button type="button" class="password-toggle-btn" id="togglePasswordBtn1" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); font-size: 0.8rem; color: var(--clr-accent); border: none; background: none; font-weight: 600;">Show</button>
            </div>
            
            <!-- Real-time Password Strength Indicator -->
            <div class="password-strength-wrapper" id="passwordStrengthWrapper" style="display: none; margin-top: 0.5rem;">
              <div class="strength-bar-bg">
                <div id="strengthBar" class="strength-bar"></div>
              </div>
              <span id="strengthText" class="strength-label">Password Strength: Weak</span>
            </div>
          </div>

          <div class="form-group" style="text-align: left;">
            <label for="signupConfirmPassword" style="display: block; font-size: 0.85rem; color: var(--clr-muted); margin-bottom: 0.5rem; font-weight: 500;">Confirm Password</label>
            <div style="position: relative;">
              <input type="password" id="signupConfirmPassword" class="form-control" placeholder="••••••••" required style="padding-right: 3.5rem;">
              <button type="button" class="password-toggle-btn" id="togglePasswordBtn2" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); font-size: 0.8rem; color: var(--clr-accent); border: none; background: none; font-weight: 600;">Show</button>
            </div>
          </div>

          <button type="submit" class="btn btn-primary" id="btnSignup3" style="width: 100%; font-family: var(--font-heading); font-weight: 600; padding: 0.85rem; margin-top: 0.5rem;">
            <span class="btn-text">Complete Registration</span>
            <div class="btn-loader" style="display: none;">
              <span class="spinner-sm"></span>
              <span>Saving password...</span>
            </div>
          </button>
        </form>
      </div>

      <!-- STEP 4: Success Onboarding -->
      <div id="signupStep4" class="auth-step-panel text-center">
        <div class="success-icon-wrapper">
          <div class="success-icon-circle">✓</div>
        </div>
        <h2 style="font-size: 1.85rem; margin-bottom: 0.5rem; font-family: var(--font-heading);">Welcome to ShortLink Pro</h2>
        <p class="text-muted" style="font-size: 0.95rem; line-height: 1.5; margin-bottom: 0;">Your account has been verified successfully.<br>Redirecting to dashboard...</p>
      </div>

    </div>

    <!-- Right Column: Welcome Onboarding Panel -->
    <div class="auth-benefits-panel glass-panel" style="animation: scaleUp 0.3s ease-out forwards; text-align: left;">
      <h3 class="onboarding-title" style="margin-bottom: 1.5rem;">Join ShortLink Pro</h3>
      
      <p style="font-size: 1.05rem; line-height: 1.5; color: var(--clr-text); font-weight: 500; margin-bottom: 2rem;">
        Join creators, students, businesses, and developers using ShortLink Pro to manage and track links smarter.
      </p>
      
      <h5 class="text-muted" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.25rem; font-weight: 700;">Account Features</h5>
      
      <ul class="onboarding-list" style="margin-top: 0;">
        <li class="onboarding-item">
          <div class="onboarding-icon" style="background: rgba(6, 182, 212, 0.1); color: var(--clr-accent); border-color: rgba(6, 182, 212, 0.2);">🔗</div>
          <div class="onboarding-text">
            <h5>Permanent storage & custom aliases</h5>
            <p>Save links forever, choose custom vanity codes, and define custom redirect codes.</p>
          </div>
        </li>
        <li class="onboarding-item">
          <div class="onboarding-icon" style="background: rgba(124, 58, 237, 0.1); color: var(--clr-secondary); border-color: rgba(124, 58, 237, 0.2);">📊</div>
          <div class="onboarding-text">
            <h5>Advanced tracking & CSV exports</h5>
            <p>Access complete analytics dashboards and download CSV archives of all links anytime.</p>
          </div>
        </li>
        <li class="onboarding-item">
          <div class="onboarding-icon" style="background: rgba(16, 185, 129, 0.1); color: var(--clr-success); border-color: rgba(16, 185, 129, 0.2);">📱</div>
          <div class="onboarding-text">
            <h5>QR code downloads</h5>
            <p>Generate high-quality vector images for print flyers, presentations, or business cards.</p>
          </div>
        </li>
      </ul>
    </div>

  </div>
</main>

<%- include('partials/footer') %>
