<%- include('partials/header') %>

<main class="hero-section" style="padding: 4rem 0; min-height: calc(100vh - var(--nav-height) - 150px); display: flex; align-items: center; justify-content: center;">
  <div class="glass-panel" style="width: 100%; max-width: 420px; padding: 2.5rem; animation: scaleUp 0.3s ease-out forwards; position: relative;">
    <h2 style="font-size: 1.75rem; margin-bottom: 0.5rem; text-align: center;">Reset Password</h2>
    <p class="text-muted" style="text-align: center; margin-bottom: 2rem; font-size: 0.9rem;">Enter your email to receive a password reset link</p>

    <form id="forgotForm" class="modal-form" style="display: flex; flex-direction: column; gap: 1.25rem;">
      <div class="form-group" style="margin-bottom: 0;">
        <label for="forgotEmail" style="display: block; font-size: 0.85rem; color: var(--clr-muted); margin-bottom: 0.5rem;">Email Address</label>
        <input type="email" id="forgotEmail" class="form-control" placeholder="you@example.com" required>
      </div>

      <button type="submit" class="btn btn-primary" id="forgotSubmitBtn" style="width: 100%; font-family: var(--font-heading); font-weight: 600; padding: 0.85rem; margin-top: 0.5rem;">
        <span class="btn-text">Send Reset Link</span>
        <div class="btn-loader" style="display: none;">
          <span class="spinner-sm"></span>
          <span>Sending...</span>
        </div>
      </button>
    </form>

    <p class="text-muted" style="text-align: center; margin-top: 2rem; font-size: 0.85rem; margin-bottom: 0;">
      Remembered your password? <a href="/login" style="color: var(--clr-accent); font-weight: 600;">Sign in</a>
    </p>
  </div>
</main>

<%- include('partials/footer') %>
