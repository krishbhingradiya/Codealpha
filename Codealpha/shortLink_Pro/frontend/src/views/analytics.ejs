<%- include('partials/header') %>

<main class="analytics-section">
  <!-- Dynamic configuration variables for the main.js script -->
  <script>
    const shortCode = '<%= shortCode %>';
  </script>

  <div class="analytics-container">
    <div class="analytics-header">
      <a href="/dashboard" class="btn btn-ghost btn-sm">◀️ Back to Dashboard</a>
      <h1 class="analytics-title">Link Analytics</h1>
      <p class="analytics-subtitle" id="analyticsShortUrl">Loading short URL...</p>
    </div>

    <!-- Loading state indicator -->
    <div class="loading-state glass-panel" id="analyticsLoading">
      <div class="spinner-lg"></div>
      <p>Gathering latest engagement metrics...</p>
    </div>

    <!-- Core analytics layout grid -->
    <div id="analyticsContent" style="display: none;">
      <!-- Main Overview Cards -->
      <section class="analytics-overview">
        <div class="analytics-stat-card glass-panel">
          <div class="stat-num gradient-text" id="analyticsClicks">0</div>
          <div class="stat-label">Total Redirection Clicks</div>
        </div>
        <div class="analytics-stat-card glass-panel">
          <div class="stat-num" id="analyticsStatus" style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">Active</div>
          <div class="stat-label">Link Status</div>
        </div>
        <div class="analytics-stat-card glass-panel">
          <div class="stat-num" id="analyticsCreated" style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">N/A</div>
          <div class="stat-label">Created Time</div>
        </div>
        <div class="analytics-stat-card glass-panel">
          <div class="stat-num" id="analyticsLastVisit" style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">N/A</div>
          <div class="stat-label">Last Visited Time</div>
        </div>
      </section>

      <!-- Details & QR Codes Layout -->
      <div class="analytics-layout">
        <!-- Configuration metrics card -->
        <div class="analytics-details glass-panel">
          <h3 class="panel-title">Link Settings</h3>
          <div class="detail-list">
            <div class="detail-row">
              <span class="detail-label">Short Code</span>
              <span class="detail-value" id="analyticsCode">N/A</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Original Destination</span>
              <a href="#" target="_blank" class="detail-value text-accent" id="analyticsOriginal">Loading...</a>
            </div>
            <div class="detail-row">
              <span class="detail-label">Created At</span>
              <span class="detail-value" id="analyticsCreatedFull">N/A</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Last Updated At</span>
              <span class="detail-value" id="analyticsUpdated">N/A</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Expiration Date</span>
              <span class="detail-value" id="analyticsExpires">N/A</span>
            </div>
          </div>
          <div style="margin-top: 1.5rem; display: flex; gap: 1rem;">
            <a href="#" target="_blank" class="btn btn-primary" id="analyticsVisitBtn">Visit Link</a>
            <button class="btn btn-secondary" id="analyticsCopyBtn">Copy Link</button>
          </div>
        </div>

        <!-- QR Code display panel -->
        <div class="analytics-qr glass-panel text-center">
          <h3 class="panel-title">Interact QR Code</h3>
          <img id="analyticsQr" src="" alt="Branded QR Code" class="analytics-qr-img">
          <button id="analyticsQrDownload" class="btn btn-primary btn-sm">Download High Res</button>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
