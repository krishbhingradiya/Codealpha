<header class="bg-white shadow-sm border-b border-gray-100 sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <i class="ri-restaurant-2-fill text-white text-lg"></i>
        </div>
        <span class="text-xl font-bold text-secondary">Dine<span class="text-primary">Flow</span></span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1">
        <a href="/" class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50 transition-colors">
          <i class="ri-restaurant-line mr-1"></i>Menu
        </a>
        
        <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
          <% if (!user || user.role === 'customer') { %>
          <a href="/reservations/new" class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50 transition-colors">
            <i class="ri-calendar-check-line mr-1"></i>Reserve
          </a>
          <a href="/orders/history" class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50 transition-colors">
            <i class="ri-file-list-3-line mr-1"></i>My Orders
          </a>
          <% } %>

          <% if (user && (user.role === 'manager' || user.role === 'admin')) { %>
            <div class="w-px h-6 bg-gray-200 mx-2"></div>
            <a href="/manager/dashboard" class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50 transition-colors">
              <i class="ri-dashboard-line mr-1"></i>Dashboard
            </a>
            <a href="/manager/orders" class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50 transition-colors">
              <i class="ri-list-ordered mr-1"></i>Orders
            </a>
            <a href="/manager/reservations" class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50 transition-colors">
              <i class="ri-calendar-check-line mr-1"></i>Reservations
            </a>
          <% } %>

          <% if (user && user.role === 'admin') { %>
            <a href="/admin" class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50 transition-colors">
              <i class="ri-shield-user-line mr-1"></i>Admin
            </a>
          <% } %>
        <% } %>
      </nav>

      <!-- Right Section -->
      <div class="flex items-center gap-3">
        <!-- Cart (customers only) -->
        <% if (!user || user.role === 'customer') { %>
        <a href="/cart" class="relative p-2 text-gray-500 hover:text-primary transition-colors" id="cart-icon">
          <i class="ri-shopping-cart-2-line text-xl"></i>
          <span id="cart-count" class="absolute -top-0.5 -right-0.5 w-5 h-5 bg-primary text-white text-xs rounded-full hidden items-center justify-center font-medium">0</span>
        </a>
        <% } %>

        <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
          <!-- Notifications -->
          <a href="/notifications" class="relative p-2 text-gray-500 hover:text-primary transition-colors">
            <i class="ri-notification-3-line text-xl"></i>
            <span id="notif-count" class="absolute -top-0.5 -right-0.5 w-5 h-5 bg-red-500 text-white text-xs rounded-full hidden items-center justify-center font-medium">0</span>
          </a>

          <!-- User Menu -->
          <div class="relative" id="user-menu-wrapper">
            <button onclick="toggleUserMenu()" class="flex items-center gap-2 px-3 py-1.5 rounded-lg hover:bg-gray-50 transition-colors border border-gray-200">
              <div class="w-7 h-7 bg-primary/10 text-primary rounded-full flex items-center justify-center text-sm font-semibold">
                <%= user ? user.name.charAt(0).toUpperCase() : 'U' %>
              </div>
              <span class="text-sm font-medium text-gray-700 hidden sm:block"><%= user ? user.name.split(' ')[0] : 'User' %></span>
              <i class="ri-arrow-down-s-line text-gray-400 text-sm"></i>
            </button>
            <div id="user-menu" class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-gray-100 py-1 hidden z-50">
              <div class="px-4 py-2 border-b border-gray-100">
                <p class="text-sm font-medium text-gray-900"><%= user ? user.name : '' %></p>
                <p class="text-xs text-gray-500"><%= user ? user.role.charAt(0).toUpperCase() + user.role.slice(1) : '' %></p>
              </div>
              <a href="/profile" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                <i class="ri-user-line"></i>Profile
              </a>
              <% if (!user || user.role === 'customer') { %>
              <a href="/orders/history" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                <i class="ri-history-line"></i>Order History
              </a>
              <a href="/profile/reservations" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                <i class="ri-calendar-line"></i>Reservations
              </a>
              <% } %>
              <div class="border-t border-gray-100 mt-1">
                <a href="/auth/logout" class="flex items-center gap-2 px-4 py-2 text-sm text-red-600 hover:bg-red-50">
                  <i class="ri-logout-box-r-line"></i>Logout
                </a>
              </div>
            </div>
          </div>
        <% } else { %>
          <a href="/auth/login" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-primary transition-colors">Login</a>
          <a href="/auth/register" class="px-4 py-2 text-sm font-medium bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors shadow-sm">Sign Up</a>
        <% } %>

        <!-- Mobile Menu Toggle -->
        <button onclick="toggleMobileMenu()" class="md:hidden p-2 text-gray-500 hover:text-primary">
          <i class="ri-menu-line text-xl" id="mobile-menu-icon"></i>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="md:hidden hidden pb-4 border-t border-gray-100 mt-2 pt-3">
      <a href="/" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50">
        <i class="ri-restaurant-line mr-2"></i>Menu
      </a>
      <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated) { %>
        <% if (!user || user.role === 'customer') { %>
        <a href="/reservations/new" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50">
          <i class="ri-calendar-check-line mr-2"></i>Reserve a Table
        </a>
        <a href="/orders/history" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50">
          <i class="ri-file-list-3-line mr-2"></i>My Orders
        </a>
        <% } %>
        <% if (user && (user.role === 'manager' || user.role === 'admin')) { %>
          <div class="border-t border-gray-100 my-2"></div>
          <a href="/manager/dashboard" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50">
            <i class="ri-dashboard-line mr-2"></i>Dashboard
          </a>
          <a href="/manager/orders" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50">
            <i class="ri-list-ordered mr-2"></i>Manage Orders
          </a>
          <a href="/manager/reservations" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50">
            <i class="ri-calendar-check-line mr-2"></i>Reservations
          </a>
          <a href="/manager/menu" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50">
            <i class="ri-book-open-line mr-2"></i>Manage Menu
          </a>
          <a href="/manager/tables" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50">
            <i class="ri-layout-grid-line mr-2"></i>Tables
          </a>
          <a href="/manager/inventory" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50">
            <i class="ri-archive-line mr-2"></i>Inventory
          </a>
        <% } %>
        <% if (user && user.role === 'admin') { %>
          <a href="/admin" class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary rounded-lg hover:bg-orange-50">
            <i class="ri-shield-user-line mr-2"></i>Admin Panel
          </a>
        <% } %>
      <% } %>
    </div>
  </div>
</header>

<!-- Canvas Confetti -->
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

<!-- Welcome Coupon Modal Overlay -->
<div id="welcome-popup-overlay" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/50 backdrop-blur-xs hidden" onclick="closeWelcomePopup(event)">
  <div class="bg-white rounded-3xl border border-gray-100 p-8 max-w-md w-full mx-4 shadow-2xl relative overflow-hidden transform scale-95 transition-all duration-300 ease-out" id="welcome-popup-card" onclick="event.stopPropagation()">
    <!-- Top accent circle decoration -->
    <div class="absolute -top-10 -right-10 w-32 h-32 bg-orange-100 rounded-full opacity-50 z-0"></div>
    <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-orange-50 rounded-full opacity-50 z-0"></div>
    
    <!-- Close button -->
    <button onclick="dismissWelcomePopup()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors z-10">
      <i class="ri-close-line text-2xl"></i>
    </button>
    
    <div class="relative z-10 text-center">
      <!-- Icon badge -->
      <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4 animate-bounce">
        <i class="ri-gift-2-line text-primary text-3xl"></i>
      </div>
      
      <!-- Headline -->
      <h2 class="text-2xl font-extrabold text-secondary tracking-tight">Welcome to DineFlow!</h2>
      <p class="text-sm text-gray-500 mt-2">Here is a special gift for your first dining order. Get 20% off up to ₹200 on orders above ₹299!</p>
      
      <!-- Coupon Code Card -->
      <div class="mt-6 p-4 bg-orange-50/50 border border-orange-100 rounded-2xl flex flex-col items-center gap-2">
        <span class="text-xs font-semibold text-orange-600 uppercase tracking-widest">Your Coupon Code</span>
        <div class="flex items-center gap-3">
          <span id="welcome-coupon-code" class="text-3xl font-black text-secondary tracking-wider">WELCOME20</span>
          <button onclick="copyWelcomeCode()" id="welcome-copy-btn" class="w-9 h-9 bg-white rounded-xl border border-gray-200 text-gray-500 hover:text-primary hover:border-primary transition-all flex items-center justify-center shadow-sm" title="Copy code">
            <i class="ri-file-copy-line text-lg" id="welcome-copy-icon"></i>
          </button>
        </div>
        <span id="welcome-copy-feedback" class="text-[10px] text-green-600 font-bold hidden">Copied to clipboard! 🎉</span>
      </div>

      <!-- Action Button -->
      <button onclick="dismissWelcomePopup()" class="mt-6 w-full py-3 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-all shadow-md hover:shadow-lg">
        Claim Offer
      </button>
      
      <!-- Dismiss Timer -->
      <p id="welcome-popup-timer" class="text-xs text-gray-400 mt-4 font-medium">Closing in 10s...</p>
    </div>
  </div>
</div>

<style>
  #welcome-popup-overlay.show {
    display: flex !important;
  }
  #welcome-popup-card {
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  #welcome-popup-overlay.show #welcome-popup-card {
    transform: scale(1) !important;
  }
</style>

<script>
  let welcomeTimerId = null;
  let welcomeSecondsRemaining = 10;

  function initWelcomePopup() {
    // Only query backend if not checked in this session
    if (sessionStorage.getItem('welcome_popup_checked')) {
      return;
    }

    fetch('/api/coupons/welcome-check')
      .then(res => res.json())
      .then(data => {
        sessionStorage.setItem('welcome_popup_checked', 'true');
        if (data.showPopup && data.couponCode) {
          // Show the popup
          const overlay = document.getElementById('welcome-popup-overlay');
          if (overlay) {
            overlay.classList.add('show');
            overlay.classList.remove('hidden');
            
            // Fire welcome confetti
            fireWelcomeConfetti();
            
            // Start countdown
            startWelcomePopupCountdown();
          }
        }
      })
      .catch(err => console.error('Failed to check welcome popup:', err));
  }

  function startWelcomePopupCountdown() {
    const timerText = document.getElementById('welcome-popup-timer');
    if (!timerText) return;
    
    welcomeSecondsRemaining = 10;
    timerText.textContent = `Closing in ${welcomeSecondsRemaining}s...`;
    
    welcomeTimerId = setInterval(() => {
      welcomeSecondsRemaining--;
      if (welcomeSecondsRemaining <= 0) {
        dismissWelcomePopup();
      } else {
        timerText.textContent = `Closing in ${welcomeSecondsRemaining}s...`;
      }
    }, 1000);
  }

  function dismissWelcomePopup() {
    if (welcomeTimerId) {
      clearInterval(welcomeTimerId);
      welcomeTimerId = null;
    }
    const overlay = document.getElementById('welcome-popup-overlay');
    if (overlay) {
      overlay.classList.remove('show');
      setTimeout(() => overlay.classList.add('hidden'), 300);
    }
  }

  function closeWelcomePopup(event) {
    dismissWelcomePopup();
  }

  function copyWelcomeCode() {
    const codeText = 'WELCOME20';
    navigator.clipboard.writeText(codeText)
      .then(() => {
        // Change icon and show feedback
        const copyIcon = document.getElementById('welcome-copy-icon');
        const feedback = document.getElementById('welcome-copy-feedback');
        
        if (copyIcon) {
          copyIcon.className = 'ri-check-line text-green-500';
        }
        if (feedback) {
          feedback.classList.remove('hidden');
        }
        
        // Launch confetti burst on copy success
        confetti({
          particleCount: 50,
          spread: 60,
          origin: { y: 0.8 }
        });
        
        // Reset copy button after 2s
        setTimeout(() => {
          if (copyIcon) {
            copyIcon.className = 'ri-file-copy-line text-lg';
          }
          if (feedback) {
            feedback.classList.add('hidden');
          }
        }, 2000);
      })
      .catch(err => console.error('Failed to copy code:', err));
  }

  function fireWelcomeConfetti() {
    // Elegant fireworks/confetti on opening
    var duration = 2 * 1000;
    var end = Date.now() + duration;

    (function frame() {
      confetti({
        particleCount: 2,
        angle: 60,
        spread: 55,
        origin: { x: 0 },
        colors: ['#F97316', '#FED7AA', '#ea580c']
      });
      confetti({
        particleCount: 2,
        angle: 120,
        spread: 55,
        origin: { x: 1 },
        colors: ['#F97316', '#FED7AA', '#ea580c']
      });

      if (Date.now() < end) {
        requestAnimationFrame(frame);
      }
    }());
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Small delay to let page load smoothly before popup shows
    setTimeout(initWelcomePopup, 1500);
  });
</script>
