<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-secondary"><i class="ri-bar-chart-2-line mr-2 text-primary"></i>Reports</h1>
    <div class="flex gap-2">
      <a href="/admin/reports/sales/csv?period=<%= currentPeriod %>" class="px-4 py-2 bg-secondary text-white rounded-xl text-sm font-medium hover:bg-gray-800 transition-colors">
        <i class="ri-download-line mr-1"></i>Export Sales CSV
      </a>
      <a href="/admin/reports/inventory/csv" class="px-4 py-2 bg-gray-200 text-secondary rounded-xl text-sm font-medium hover:bg-gray-300 transition-colors">
        <i class="ri-download-line mr-1"></i>Inventory CSV
      </a>
    </div>
  </div>

  <!-- Period Filter -->
  <div class="flex gap-2 mb-6">
    <a href="/admin/reports?period=daily" class="px-4 py-2 rounded-full text-sm font-medium <%= currentPeriod === 'daily' ? 'bg-primary text-white' : 'bg-white text-gray-600 border border-gray-200' %> transition-colors">Daily</a>
    <a href="/admin/reports?period=weekly" class="px-4 py-2 rounded-full text-sm font-medium <%= currentPeriod === 'weekly' ? 'bg-primary text-white' : 'bg-white text-gray-600 border border-gray-200' %> transition-colors">Weekly</a>
    <a href="/admin/reports?period=monthly" class="px-4 py-2 rounded-full text-sm font-medium <%= currentPeriod === 'monthly' ? 'bg-primary text-white' : 'bg-white text-gray-600 border border-gray-200' %> transition-colors">Monthly</a>
  </div>

  <!-- Sales Summary -->
  <div class="grid md:grid-cols-3 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-gray-100 p-5">
      <p class="text-sm text-gray-500 mb-1">Total Revenue</p>
      <p class="text-3xl font-bold text-primary"><%= formatCurrency(salesReport.totalRevenue) %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-100 p-5">
      <p class="text-sm text-gray-500 mb-1">Total Orders</p>
      <p class="text-3xl font-bold text-secondary"><%= salesReport.totalOrders %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-100 p-5">
      <p class="text-sm text-gray-500 mb-1">Avg. Order Value</p>
      <p class="text-3xl font-bold text-secondary"><%= formatCurrency(salesReport.averageOrderValue) %></p>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <!-- Top Selling Items -->
    <div class="bg-white rounded-xl border border-gray-100 p-6">
      <h2 class="font-semibold text-secondary mb-4">Top Selling Items</h2>
      <% if (topItems.length === 0) { %>
        <p class="text-sm text-gray-400 text-center py-8">No data available</p>
      <% } else { %>
        <div class="space-y-3">
          <% topItems.forEach((item, i) => { %>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="w-7 h-7 bg-primary/10 text-primary rounded-lg flex items-center justify-center text-xs font-bold"><%= i + 1 %></span>
                <span class="text-sm font-medium"><%= item.name %></span>
              </div>
              <div class="text-right">
                <p class="text-sm font-medium text-primary"><%= formatCurrency(item.totalRevenue) %></p>
                <p class="text-xs text-gray-400"><%= item.totalQuantity %> sold</p>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Most Ordered Categories -->
    <div class="bg-white rounded-xl border border-gray-100 p-6">
      <h2 class="font-semibold text-secondary mb-4">Most Ordered Categories</h2>
      <% if (categories.length === 0) { %>
        <p class="text-sm text-gray-400 text-center py-8">No data available</p>
      <% } else { %>
        <div class="space-y-3">
          <% categories.forEach((cat, i) => { %>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="w-7 h-7 bg-orange-50 text-orange-600 rounded-lg flex items-center justify-center text-xs font-bold"><%= i + 1 %></span>
                <span class="text-sm font-medium"><%= cat.name %></span>
              </div>
              <span class="text-sm font-medium"><%= cat.totalOrders %> orders</span>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Sales Orders Table -->
  <div class="mt-6 bg-white rounded-xl border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="font-semibold text-secondary">Sales Orders (<%= currentPeriod %>)</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">Order #</th>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">Customer</th>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">Amount</th>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% salesReport.orders.forEach(o => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 text-sm font-medium">#<%= o.order_number %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= o.users ? o.users.name : 'N/A' %></td>
              <td class="px-4 py-3 text-sm font-medium text-primary"><%= formatCurrency(o.total_amount) %></td>
              <td class="px-4 py-3 text-sm text-gray-400"><%= new Date(o.created_at).toLocaleString() %></td>
            </tr>
          <% }) %>
          <% if (salesReport.orders.length === 0) { %>
            <tr><td colspan="4" class="px-4 py-8 text-center text-gray-400">No sales data for this period</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
