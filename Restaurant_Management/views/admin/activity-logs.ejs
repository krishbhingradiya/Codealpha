<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-secondary mb-6"><i class="ri-history-line mr-2 text-primary"></i>Activity Logs</h1>

  <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">User</th>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">Action</th>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">Details</th>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">Timestamp</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% logs.forEach(log => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3">
                <div class="flex items-center gap-2">
                  <div class="w-7 h-7 bg-gray-100 rounded-full flex items-center justify-center text-xs font-semibold text-gray-600">
                    <%= log.users ? log.users.name.charAt(0).toUpperCase() : '?' %>
                  </div>
                  <div>
                    <p class="text-sm font-medium"><%= log.users ? log.users.name : 'System' %></p>
                    <p class="text-xs text-gray-400"><%= log.users ? log.users.role : '' %></p>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 text-sm text-gray-700"><%= log.action %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= log.details || '-' %></td>
              <td class="px-4 py-3 text-sm text-gray-400"><%= new Date(log.created_at).toLocaleString() %></td>
            </tr>
          <% }) %>
          <% if (logs.length === 0) { %>
            <tr><td colspan="4" class="px-4 py-8 text-center text-gray-400">No activity logs</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
