<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-secondary"><i class="ri-group-line mr-2 text-primary"></i>Manage Users</h1>
  </div>

  <!-- Search & Filter -->
  <div class="flex flex-wrap gap-3 mb-6">
    <form action="/admin/users" method="GET" class="flex-1 flex gap-2">
      <input type="text" name="search" value="<%= searchQuery %>" placeholder="Search by name or email..."
        class="flex-1 px-4 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none">
      <button type="submit" class="px-4 py-2 bg-primary text-white rounded-xl text-sm font-medium">Search</button>
    </form>
    <div class="flex gap-2">
      <a href="/admin/users" class="px-4 py-2 rounded-full text-sm font-medium <%= currentRole === 'all' ? 'bg-primary text-white' : 'bg-white text-gray-600 border border-gray-200' %> transition-colors">All</a>
      <a href="/admin/users?role=customer" class="px-4 py-2 rounded-full text-sm font-medium <%= currentRole === 'customer' ? 'bg-primary text-white' : 'bg-white text-gray-600 border border-gray-200' %> transition-colors">Customers</a>
      <a href="/admin/users?role=manager" class="px-4 py-2 rounded-full text-sm font-medium <%= currentRole === 'manager' ? 'bg-primary text-white' : 'bg-white text-gray-600 border border-gray-200' %> transition-colors">Managers</a>
      <a href="/admin/users?role=admin" class="px-4 py-2 rounded-full text-sm font-medium <%= currentRole === 'admin' ? 'bg-primary text-white' : 'bg-white text-gray-600 border border-gray-200' %> transition-colors">Admins</a>
    </div>
  </div>

  <!-- Users Table -->
  <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">User</th>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">Email</th>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">Mobile</th>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">Role</th>
            <th class="text-left text-xs font-medium text-gray-500 uppercase px-4 py-3">Joined</th>
            <th class="text-right text-xs font-medium text-gray-500 uppercase px-4 py-3">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% users.forEach(u => { %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 bg-primary/10 text-primary rounded-full flex items-center justify-center text-sm font-semibold">
                    <%= u.name.charAt(0).toUpperCase() %>
                  </div>
                  <span class="text-sm font-medium"><%= u.name %></span>
                </div>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= u.email %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= u.mobile || '-' %></td>
              <td class="px-4 py-3">
                <form action="/admin/users/<%= u.id %>/role" method="POST" class="flex items-center gap-2">
                  <select name="role" class="px-2 py-1 border border-gray-200 rounded-lg text-xs">
                    <option value="customer" <%= u.role === 'customer' ? 'selected' : '' %>>Customer</option>
                    <option value="manager" <%= u.role === 'manager' ? 'selected' : '' %>>Manager</option>
                    <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                  </select>
                  <button type="submit" class="px-2 py-1 bg-primary text-white rounded-lg text-xs">Set</button>
                </form>
              </td>
              <td class="px-4 py-3 text-sm text-gray-400"><%= new Date(u.created_at).toLocaleDateString() %></td>
              <td class="px-4 py-3 text-right">
                <form action="/admin/users/<%= u.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Delete this user?')">
                  <button type="submit" class="text-red-400 hover:text-red-600"><i class="ri-delete-bin-line"></i></button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
