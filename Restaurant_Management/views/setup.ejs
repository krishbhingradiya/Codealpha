<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DineFlow — Database Setup Required</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.1.0/fonts/remixicon.css" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: { DEFAULT: '#F97316', dark: '#EA580C', light: '#FFF7ED' },
            secondary: { DEFAULT: '#334155', light: '#64748B' }
          },
          fontFamily: { sans: ['Inter', 'sans-serif'] }
        }
      }
    }
  </script>
</head>
<body class="bg-gray-50 font-sans min-h-screen flex items-center justify-center p-4">
  <div class="max-w-2xl w-full">
    <div class="text-center mb-8">
      <div class="inline-flex items-center gap-2 text-2xl font-bold text-secondary">
        <span class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-white text-lg">🍽️</span>
        DineFlow
      </div>
    </div>
    
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
      <div class="text-center mb-6">
        <div class="w-16 h-16 bg-orange-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <i class="ri-database-2-line text-3xl text-primary"></i>
        </div>
        <h1 class="text-2xl font-bold text-secondary">Database Setup Required</h1>
        <p class="text-gray-500 mt-2">Your database tables haven't been created yet. Follow the steps below to set up your database.</p>
      </div>

      <div class="space-y-4">
        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center flex-shrink-0 text-sm font-semibold">1</div>
          <div>
            <h3 class="font-semibold text-secondary">Open Supabase SQL Editor</h3>
            <p class="text-sm text-gray-500 mt-1">Go to your Supabase Dashboard and open the SQL Editor:</p>
            <a href="https://supabase.com/dashboard/project/kpqjzhqrruwwoljmiuju/sql/new" target="_blank" 
               class="inline-flex items-center gap-1 text-sm text-primary hover:underline mt-1">
              <i class="ri-external-link-line"></i>Open SQL Editor
            </a>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center flex-shrink-0 text-sm font-semibold">2</div>
          <div>
            <h3 class="font-semibold text-secondary">Run the Migration SQL</h3>
            <p class="text-sm text-gray-500 mt-1">Copy the contents of the file below and paste it into the SQL Editor, then click <strong>Run</strong>.</p>
            <div class="mt-2 bg-gray-50 rounded-xl p-3 border border-gray-100">
              <code class="text-xs text-secondary break-all">migrations/001_initial_schema.sql</code>
              <button onclick="copyPath()" class="ml-2 text-xs text-primary hover:underline" id="copy-btn">Copy path</button>
            </div>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center flex-shrink-0 text-sm font-semibold">3</div>
          <div>
            <h3 class="font-semibold text-secondary">Restart & Verify</h3>
            <p class="text-sm text-gray-500 mt-1">After running the migration, restart the server and reload this page.</p>
          </div>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-gray-100">
        <a href="/" class="w-full inline-flex items-center justify-center gap-2 px-6 py-2.5 bg-primary text-white rounded-xl hover:bg-primary-dark transition-colors text-sm font-medium">
          <i class="ri-refresh-line"></i>Reload & Check Again
        </a>
      </div>

      <div class="mt-4 p-3 bg-orange-50 rounded-xl">
        <p class="text-xs text-orange-700">
          <i class="ri-information-line"></i> 
          <strong>Default Admin Login</strong> (after migration): <code>admin@restaurant.com</code> / <code>Admin@123</code>
        </p>
      </div>
    </div>
  </div>

  <script>
    function copyPath() {
      navigator.clipboard.writeText('migrations/001_initial_schema.sql');
      document.getElementById('copy-btn').textContent = 'Copied!';
      setTimeout(() => document.getElementById('copy-btn').textContent = 'Copy path', 2000);
    }
  </script>
</body>
</html>
