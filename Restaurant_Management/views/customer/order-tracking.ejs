<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <a href="/orders/history" class="text-primary hover:underline text-sm"><i class="ri-arrow-left-line mr-1"></i>Back to Orders</a>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 p-6 md:p-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-secondary">Order #<%= order.order_number %></h1>
        <p class="text-gray-500 text-sm mt-1">
          Placed on <%= new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
        </p>
      </div>
      <% if (order.table_number) { %>
        <span class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium">
          <i class="ri-layout-grid-line mr-1"></i>Table <%= order.table_number %>
        </span>
      <% } %>
    </div>

    <!-- Status Tracker -->
    <div class="mb-8">
      <div class="flex items-center justify-between relative">
        <div class="absolute top-4 left-0 right-0 h-0.5 bg-gray-200"></div>
        <%
          const statuses = ['pending', 'preparing', 'ready', 'served', 'completed'];
          const statusIcons = { pending: 'ri-time-line', preparing: 'ri-fire-line', ready: 'ri-check-double-line', served: 'ri-hand-heart-line', completed: 'ri-checkbox-circle-line' };
          const statusLabels = { pending: 'Pending', preparing: 'Preparing', ready: 'Ready', served: 'Served', completed: 'Completed' };
          const currentIdx = statuses.indexOf(order.status);
          const isCancelled = order.status === 'cancelled';
        %>
        <% statuses.forEach((s, i) => { %>
          <div class="relative flex flex-col items-center z-10">
            <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-medium
              <%= isCancelled ? 'bg-gray-200 text-gray-400' : (i <= currentIdx ? 'bg-primary text-white' : 'bg-gray-200 text-gray-400') %>">
              <i class="<%= statusIcons[s] %>"></i>
            </div>
            <span class="text-xs mt-2 font-medium <%= i <= currentIdx && !isCancelled ? 'text-primary' : 'text-gray-400' %> hidden sm:block"><%= statusLabels[s] %></span>
          </div>
        <% }) %>
      </div>
      <% if (isCancelled) { %>
        <div class="mt-4 text-center">
          <span class="px-4 py-2 bg-red-50 text-red-700 rounded-lg text-sm font-medium">
            <i class="ri-close-circle-line mr-1"></i>This order has been cancelled
          </span>
        </div>
      <% } %>
    </div>

    <!-- Order Items -->
    <div class="border-t border-gray-100 pt-6">
      <h2 class="font-semibold text-secondary mb-4">Order Items</h2>
      <div class="space-y-3">
        <% if (order.items && order.items.length > 0) { %>
          <% order.items.forEach(item => { %>
            <div class="flex items-center justify-between py-3 border-b border-gray-50 last:border-0">
              <div class="flex items-center gap-3">
                <span class="w-8 h-8 bg-orange-50 rounded-lg flex items-center justify-center text-sm font-bold text-primary"><%= item.quantity %>x</span>
                <span class="font-medium text-sm"><%= item.item_name || (item.menu_items ? item.menu_items.name : 'Item') %></span>
              </div>
              <span class="font-medium text-sm"><%= formatCurrency(parseFloat(item.price) * item.quantity) %></span>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <% if (order.special_instructions) { %>
      <div class="mt-4 p-3 bg-amber-50 rounded-xl">
        <p class="text-sm text-amber-800"><i class="ri-chat-1-line mr-1"></i><strong>Note:</strong> <%= order.special_instructions %></p>
      </div>
    <% } %>

    <!-- Total -->
    <div class="mt-6 pt-4 border-t border-gray-100 flex justify-between items-center">
      <span class="font-semibold text-lg">Total</span>
      <span class="text-2xl font-bold text-primary"><%= formatCurrency(order.total_amount) %></span>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const currentStatus = '<%= order.status %>';
    const orderId = '<%= order.id %>';
    
    // Poll for status updates every 5 seconds
    if (currentStatus !== 'completed' && currentStatus !== 'cancelled') {
      const interval = setInterval(async () => {
        try {
          const res = await fetch(`/api/orders/${orderId}`);
          if (res.ok) {
            const data = await res.json();
            if (data.status !== currentStatus) {
              clearInterval(interval);
              window.location.reload();
            }
          }
        } catch (err) {
          console.error('Error polling order status:', err);
        }
      }, 5000);
    }
  });
</script>
