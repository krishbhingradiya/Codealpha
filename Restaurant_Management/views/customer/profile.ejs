<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-secondary mb-6"><i class="ri-user-line mr-2 text-primary"></i>My Profile</h1>

  <!-- Stats Cards -->
  <div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-2xl border border-gray-100 p-5 shadow-sm">
      <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center mb-3">
        <i class="ri-shopping-bag-3-line text-primary text-xl"></i>
      </div>
      <p class="text-xl font-extrabold text-secondary"><%= stats.totalOrders %></p>
      <p class="text-[10px] text-gray-500 mt-0.5 uppercase tracking-wider font-semibold">Total Orders</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 p-5 shadow-sm">
      <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center mb-3">
        <span class="text-green-500 font-extrabold text-lg">₹</span>
      </div>
      <p class="text-xl font-extrabold text-secondary"><%= formatCurrency(stats.savingsEarned) %></p>
      <p class="text-[10px] text-gray-500 mt-0.5 uppercase tracking-wider font-semibold">Savings Earned</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 p-5 shadow-sm">
      <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center mb-3">
        <i class="ri-coupon-3-line text-blue-500 text-xl"></i>
      </div>
      <p class="text-xl font-extrabold text-secondary"><%= stats.couponsUsed %></p>
      <p class="text-[10px] text-gray-500 mt-0.5 uppercase tracking-wider font-semibold">Coupons Used</p>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-6">
    <!-- Profile Card -->
    <div class="bg-white rounded-2xl border border-gray-100 p-6">
      <div class="text-center mb-6">
        <div class="w-20 h-20 bg-primary/10 text-primary rounded-2xl flex items-center justify-center mx-auto mb-3 text-3xl font-bold">
          <%= profile.name.charAt(0).toUpperCase() %>
        </div>
        <h2 class="font-semibold text-lg"><%= profile.name %></h2>
        <p class="text-gray-500 text-sm"><%= profile.email %></p>
        <span class="inline-flex items-center px-3 py-1 bg-primary/10 text-primary rounded-full text-xs font-medium mt-2">
          <%= profile.role.charAt(0).toUpperCase() + profile.role.slice(1) %>
        </span>
      </div>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between py-2 border-b border-gray-50">
          <span class="text-gray-500">Phone</span>
          <span class="font-medium"><%= profile.mobile || 'Not set' %></span>
        </div>
        <div class="flex justify-between py-2">
          <span class="text-gray-500">Member since</span>
          <span class="font-medium"><%= new Date(profile.created_at).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %></span>
        </div>
      </div>
    </div>

    <!-- Edit Profile & Password -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Edit Profile -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6">
        <h2 class="font-semibold text-secondary mb-4">Edit Profile</h2>
        <form action="/profile/update" method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
            <input type="text" name="name" value="<%= profile.name %>" required
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Mobile Number</label>
            <input type="tel" name="mobile" value="<%= profile.mobile || '' %>"
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none text-sm">
          </div>
          <button type="submit" class="px-6 py-2.5 bg-primary text-white rounded-xl hover:bg-primary-dark transition-colors text-sm font-medium">
            Save Changes
          </button>
        </form>
      </div>

      <!-- Change Password -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6">
        <h2 class="font-semibold text-secondary mb-4">Change Password</h2>
        <form action="/profile/password" method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Current Password</label>
            <input type="password" name="currentPassword" required minlength="6"
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
            <input type="password" name="newPassword" required minlength="6"
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Confirm New Password</label>
            <input type="password" name="confirmPassword" required minlength="6"
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none text-sm">
          </div>
          <button type="submit" class="px-6 py-2.5 bg-secondary text-white rounded-xl hover:bg-gray-800 transition-colors text-sm font-medium">
            Update Password
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Recent Activity -->
  <div class="mt-8 grid md:grid-cols-2 gap-6">
    <!-- Recent Orders -->
    <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-bold text-secondary text-base flex items-center gap-2">
          <i class="ri-history-line text-primary"></i> Recent Orders
        </h3>
        <a href="/orders/history" class="text-xs font-semibold text-primary hover:underline">View All</a>
      </div>
      <% if (recentOrders.length === 0) { %>
        <p class="text-sm text-gray-400 py-4 text-center">No recent orders.</p>
      <% } else { %>
        <div class="space-y-3">
          <% recentOrders.forEach(order => { %>
            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl">
              <div>
                <p class="text-xs font-bold text-secondary">#<%= order.order_number %></p>
                <p class="text-[10px] text-gray-400"><%= new Date(order.created_at).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' }) %></p>
              </div>
              <div class="text-right flex items-center gap-2">
                <span class="text-xs font-semibold text-primary"><%= formatCurrency(order.total_amount) %></span>
                <a href="/invoice/<%= order.id %>" target="_blank" class="w-7 h-7 bg-white rounded-lg border border-gray-200 flex items-center justify-center text-secondary hover:text-primary hover:border-primary transition-all" title="View Invoice">
                  <i class="ri-file-text-line text-sm"></i>
                </a>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Recent Reservations -->
    <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-bold text-secondary text-base flex items-center gap-2">
          <i class="ri-calendar-event-line text-primary"></i> Recent Reservations
        </h3>
        <a href="/reservations" class="text-xs font-semibold text-primary hover:underline">View All</a>
      </div>
      <% if (reservations.length === 0) { %>
        <p class="text-sm text-gray-400 py-4 text-center">No recent reservations.</p>
      <% } else { %>
        <div class="space-y-3">
          <% reservations.forEach(resv => { %>
            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl">
              <div>
                <p class="text-xs font-bold text-secondary">Table <%= resv.table_number %></p>
                <p class="text-[10px] text-gray-400">
                  <%= new Date(resv.reservation_date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' }) %> 
                  at <%= resv.reservation_time %>
                </p>
              </div>
              <div>
                <span class="inline-block px-2 py-0.5 text-[10px] font-semibold rounded-full uppercase 
                  <%= resv.status === 'confirmed' ? 'bg-green-50 text-green-700' : (resv.status === 'cancelled' ? 'bg-red-50 text-red-700' : 'bg-yellow-50 text-yellow-700') %>">
                  <%= resv.status %>
                </span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>
