<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-secondary">Analytics</h1>
      <p class="text-gray-500 text-sm mt-1">Revenue overview and top items</p>
    </div>
    <a href="/manager/dashboard" class="text-sm text-primary hover:underline">← Back to Dashboard</a>
  </div>

  <!-- Revenue Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-gray-100 p-5">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center">
          <i class="ri-calendar-line text-blue-500 text-lg"></i>
        </div>
        <span class="text-xs font-medium text-gray-400">Today</span>
      </div>
      <p class="text-2xl font-bold text-secondary"><%= formatCurrency(analytics.daily) %></p>
      <p class="text-sm text-gray-500">Daily Revenue</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 p-5">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center">
          <i class="ri-calendar-check-line text-green-500 text-lg"></i>
        </div>
        <span class="text-xs font-medium text-gray-400">This Week</span>
      </div>
      <p class="text-2xl font-bold text-secondary"><%= formatCurrency(analytics.weekly) %></p>
      <p class="text-sm text-gray-500">Weekly Revenue</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 p-5">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 bg-purple-50 rounded-xl flex items-center justify-center">
          <i class="ri-calendar-2-line text-purple-500 text-lg"></i>
        </div>
        <span class="text-xs font-medium text-gray-400">This Month</span>
      </div>
      <p class="text-2xl font-bold text-secondary"><%= formatCurrency(analytics.monthly) %></p>
      <p class="text-sm text-gray-500">Monthly Revenue</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 p-5">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-10 h-10 bg-orange-50 rounded-xl flex items-center justify-center">
          <i class="ri-funds-line text-orange-500 text-lg"></i>
        </div>
        <span class="text-xs font-medium text-gray-400">This Year</span>
      </div>
      <p class="text-2xl font-bold text-secondary"><%= formatCurrency(analytics.yearly) %></p>
      <p class="text-sm text-gray-500">Yearly Revenue</p>
    </div>
  </div>

  <!-- Top Selling Items -->
  <div class="bg-white rounded-xl border border-gray-100 p-6">
    <h2 class="font-semibold text-secondary mb-4"><i class="ri-bar-chart-box-line mr-2 text-primary"></i>Top Selling Items</h2>
    <% if (analytics.topItems && analytics.topItems.length > 0) { %>
      <div class="space-y-3">
        <% analytics.topItems.forEach((item, index) => { %>
          <div class="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
            <div class="flex items-center gap-3">
              <span class="w-7 h-7 bg-primary/10 text-primary rounded-full flex items-center justify-center text-sm font-bold"><%= index + 1 %></span>
              <span class="font-medium text-sm text-secondary"><%= item.item_name %></span>
            </div>
            <span class="text-sm font-medium text-primary"><%= item.quantity %> sold</span>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="text-sm text-gray-400 text-center py-8">No sales data yet</p>
    <% } %>
  </div>
</div>
