<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-secondary"><i class="ri-layout-grid-line mr-2 text-primary"></i>Table Management</h1>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-3 gap-4 mb-8">
    <div class="bg-green-50 border border-green-100 rounded-xl p-4 text-center">
      <p class="text-2xl font-bold text-green-700"><%= stats.available %></p>
      <p class="text-xs font-medium text-green-600">Available</p>
    </div>
    <div class="bg-yellow-50 border border-yellow-100 rounded-xl p-4 text-center">
      <p class="text-2xl font-bold text-yellow-700"><%= stats.reserved %></p>
      <p class="text-xs font-medium text-yellow-600">Reserved</p>
    </div>
    <div class="bg-red-50 border border-red-100 rounded-xl p-4 text-center">
      <p class="text-2xl font-bold text-red-700"><%= stats.occupied %></p>
      <p class="text-xs font-medium text-red-600">Occupied</p>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-6">
    <!-- Add Table Form -->
    <div class="bg-white rounded-2xl border border-gray-100 p-6 h-fit">
      <h2 class="font-semibold text-secondary mb-4">Add Table</h2>
      <form action="/manager/tables" method="POST" class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Table Number</label>
          <input type="number" name="table_number" required min="1" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Capacity</label>
          <input type="number" name="capacity" required min="1" value="4" class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none">
        </div>
        <button type="submit" class="w-full py-2.5 bg-primary text-white rounded-xl hover:bg-primary-dark transition-colors text-sm font-medium">Add Table</button>
      </form>
    </div>

    <!-- Tables Grid -->
    <div class="lg:col-span-2">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <% tables.forEach(table => { %>
          <%
            const colors = { available: 'border-green-200 bg-green-50', reserved: 'border-yellow-200 bg-yellow-50', occupied: 'border-red-200 bg-red-50' };
            const icons = { available: 'ri-check-line text-green-500', reserved: 'ri-time-line text-yellow-500', occupied: 'ri-user-fill text-red-500' };
          %>
          <div class="rounded-xl border-2 p-4 <%= colors[table.status] %> transition-all">
            <div class="flex items-center justify-between mb-2">
              <span class="font-bold text-lg text-secondary">T<%= table.table_number %></span>
              <i class="<%= icons[table.status] %> text-xl"></i>
            </div>
            <p class="text-xs text-gray-500 mb-3"><i class="ri-group-line mr-1"></i><%= table.capacity %> seats</p>
            
            <form action="/manager/tables/<%= table.id %>/status" method="POST" class="flex gap-1">
              <select name="status" class="flex-1 px-2 py-1 border border-gray-200 rounded-lg text-xs bg-white">
                <option value="available" <%= table.status === 'available' ? 'selected' : '' %>>Available</option>
                <option value="reserved" <%= table.status === 'reserved' ? 'selected' : '' %>>Reserved</option>
                <option value="occupied" <%= table.status === 'occupied' ? 'selected' : '' %>>Occupied</option>
              </select>
              <button type="submit" class="px-2 py-1 bg-secondary text-white rounded-lg text-xs">Set</button>
            </form>
            <form action="/manager/tables/<%= table.id %>/delete" method="POST" class="mt-2" onsubmit="return confirm('Delete this table?')">
              <button type="submit" class="w-full py-1 text-red-500 hover:bg-red-50 rounded-lg text-xs">Delete</button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>
