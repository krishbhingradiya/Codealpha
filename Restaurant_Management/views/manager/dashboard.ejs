<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-secondary">Manager Dashboard</h1>
      <p class="text-gray-500 text-sm mt-1">Overview of today's operations</p>
    </div>
    <span class="text-sm text-gray-500"><%= new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }) %></span>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-gray-100 p-5">
      <div class="flex items-center justify-between mb-3">
        <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center">
          <i class="ri-file-list-3-line text-blue-500 text-lg"></i>
        </div>
        <span class="text-xs font-medium text-gray-400">Today</span>
      </div>
      <p class="text-2xl font-bold text-secondary"><%= orderStats.total %></p>
      <p class="text-sm text-gray-500">Orders</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 p-5">
      <div class="flex items-center justify-between mb-3">
        <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center">
          <i class="ri-money-dollar-circle-line text-green-500 text-lg"></i>
        </div>
        <span class="text-xs font-medium text-gray-400">Today</span>
      </div>
      <p class="text-2xl font-bold text-secondary"><%= formatCurrency(orderStats.revenue) %></p>
      <p class="text-sm text-gray-500">Revenue</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 p-5">
      <div class="flex items-center justify-between mb-3">
        <div class="w-10 h-10 bg-purple-50 rounded-xl flex items-center justify-center">
          <i class="ri-calendar-check-line text-purple-500 text-lg"></i>
        </div>
      </div>
      <p class="text-2xl font-bold text-secondary"><%= reservationCount %></p>
      <p class="text-sm text-gray-500">Active Reservations</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 p-5">
      <div class="flex items-center justify-between mb-3">
        <div class="w-10 h-10 bg-orange-50 rounded-xl flex items-center justify-center">
          <i class="ri-layout-grid-line text-orange-500 text-lg"></i>
        </div>
      </div>
      <p class="text-2xl font-bold text-secondary"><%= tableStats.occupied %> / <%= tableStats.total %></p>
      <p class="text-sm text-gray-500">Tables Occupied</p>
    </div>
  </div>

  <!-- Loyalty & Promotions Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-gray-100 p-5 flex items-center justify-between shadow-xs">
      <div>
        <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider">First-Time Customers</p>
        <p class="text-2xl font-black text-secondary mt-1"><%= orderStats.firstTimeCustomers %></p>
      </div>
      <div class="w-10 h-10 bg-orange-50 text-primary rounded-xl flex items-center justify-center">
        <i class="ri-user-add-line text-lg"></i>
      </div>
    </div>
    
    <div class="bg-white rounded-xl border border-gray-100 p-5 flex items-center justify-between shadow-xs">
      <div>
        <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Coupons Redeemed Today</p>
        <p class="text-2xl font-black text-secondary mt-1"><%= orderStats.couponsUsedToday %></p>
      </div>
      <div class="w-10 h-10 bg-blue-50 text-blue-500 rounded-xl flex items-center justify-center">
        <i class="ri-coupon-3-line text-lg"></i>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 p-5 flex items-center justify-between shadow-xs">
      <div>
        <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Promo Discounts Today</p>
        <p class="text-2xl font-black text-secondary mt-1"><%= formatCurrency(orderStats.discountGivenToday) %></p>
      </div>
      <div class="w-10 h-10 bg-green-50 text-green-600 rounded-xl flex items-center justify-center font-extrabold text-base">
        ₹
      </div>
    </div>
  </div>

  <!-- Quick Status -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
    <div class="bg-yellow-50 border border-yellow-100 rounded-xl p-4 text-center">
      <p class="text-2xl font-bold text-yellow-700"><%= orderStats.pending %></p>
      <p class="text-xs font-medium text-yellow-600">Pending</p>
    </div>
    <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 text-center">
      <p class="text-2xl font-bold text-blue-700"><%= orderStats.preparing %></p>
      <p class="text-xs font-medium text-blue-600">Preparing</p>
    </div>
    <div class="bg-green-50 border border-green-100 rounded-xl p-4 text-center">
      <p class="text-2xl font-bold text-green-700"><%= orderStats.ready %></p>
      <p class="text-xs font-medium text-green-600">Ready</p>
    </div>
    <div class="bg-red-50 border border-red-100 rounded-xl p-4 text-center">
      <p class="text-2xl font-bold text-red-700"><%= lowStockItems.length %></p>
      <p class="text-xs font-medium text-red-600">Low Stock Alerts</p>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <!-- Recent Orders -->
    <div class="bg-white rounded-xl border border-gray-100 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold text-secondary">Recent Orders</h2>
        <a href="/manager/orders" class="text-sm text-primary hover:underline">View all →</a>
      </div>
      <% if (recentOrders.length === 0) { %>
        <p class="text-sm text-gray-400 text-center py-8">No orders today</p>
      <% } else { %>
        <div class="space-y-3">
          <% recentOrders.slice(0, 5).forEach(order => { %>
            <div class="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
              <div>
                <p class="font-medium text-sm">#<%= order.order_number %></p>
                <p class="text-xs text-gray-500"><%= order.users ? order.users.name : 'Guest' %></p>
              </div>
              <div class="text-right">
                <p class="font-medium text-sm text-primary"><%= formatCurrency(order.total_amount) %></p>
                <%
                  const statusColors = { pending: 'bg-yellow-100 text-yellow-800', preparing: 'bg-blue-100 text-blue-800', ready: 'bg-green-100 text-green-800', served: 'bg-purple-100 text-purple-800', completed: 'bg-green-100 text-green-800', cancelled: 'bg-red-100 text-red-800' };
                %>
                <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= statusColors[order.status] || 'bg-gray-100' %>"><%= order.status %></span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Inventory Alerts -->
    <div class="bg-white rounded-xl border border-gray-100 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold text-secondary">Inventory Alerts</h2>
        <a href="/manager/inventory" class="text-sm text-primary hover:underline">Manage →</a>
      </div>
      <% if (lowStockItems.length === 0) { %>
        <div class="text-center py-8">
          <i class="ri-checkbox-circle-line text-3xl text-green-400 mb-2 block"></i>
          <p class="text-sm text-gray-400">All stock levels are good</p>
        </div>
      <% } else { %>
        <div class="space-y-3">
          <% lowStockItems.slice(0, 5).forEach(item => { %>
            <div class="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
              <div class="flex items-center gap-2">
                <i class="ri-error-warning-fill text-red-400"></i>
                <span class="text-sm font-medium"><%= item.item_name %></span>
              </div>
              <span class="text-sm text-red-600 font-medium"><%= item.quantity %> / <%= item.minimum_stock %> <%= item.unit %></span>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Quick Links -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8">
    <a href="/manager/orders" class="bg-white rounded-xl border border-gray-100 p-5 text-center hover:shadow-md transition-shadow group">
      <i class="ri-list-ordered text-2xl text-primary mb-2 block group-hover:scale-110 transition-transform"></i>
      <span class="text-sm font-medium text-secondary">Manage Orders</span>
    </a>
    <a href="/manager/menu" class="bg-white rounded-xl border border-gray-100 p-5 text-center hover:shadow-md transition-shadow group">
      <i class="ri-book-open-line text-2xl text-primary mb-2 block group-hover:scale-110 transition-transform"></i>
      <span class="text-sm font-medium text-secondary">Manage Menu</span>
    </a>
    <a href="/manager/tables" class="bg-white rounded-xl border border-gray-100 p-5 text-center hover:shadow-md transition-shadow group">
      <i class="ri-layout-grid-line text-2xl text-primary mb-2 block group-hover:scale-110 transition-transform"></i>
      <span class="text-sm font-medium text-secondary">Manage Tables</span>
    </a>
    <a href="/manager/inventory" class="bg-white rounded-xl border border-gray-100 p-5 text-center hover:shadow-md transition-shadow group">
      <i class="ri-archive-line text-2xl text-primary mb-2 block group-hover:scale-110 transition-transform"></i>
      <span class="text-sm font-medium text-secondary">Inventory</span>
    </a>
  </div>
</div>
